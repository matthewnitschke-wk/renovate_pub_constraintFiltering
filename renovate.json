{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],

  "constraintsFiltering": "strict",
   "rangeStrategy": "bump",

  "packageRules": [
    {
      "description": "Ignore Dart SDK environment updates",
      "matchDatasources": ["dart-version", "flutter-version"],
      "enabled": false
    }
  ]
}
